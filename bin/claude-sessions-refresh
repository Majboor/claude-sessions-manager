#!/Users/hico/.pyenv/versions/3.11.9/bin/python3
"""Regenerate ~/ClaudeSessions with .app launchers for recent Claude sessions.

Each launcher is a tiny app bundle whose icon is a rendered mini terminal
window showing the session's last messages — so the Dock grid displays real
previews. Clicking one opens Terminal and resumes the session.
"""
import hashlib
import json
import os
import re
import shutil
import subprocess
import time
from pathlib import Path

from PIL import Image, ImageDraw, ImageFont
from AppKit import NSImage, NSWorkspace

PROJECTS = Path.home() / ".claude" / "projects"
OUT = Path.home() / "ClaudeSessions"
MAX_SESSIONS = 100
MIN_BYTES = 4 * 1024  # skip near-empty session stubs
STATE = Path.home() / ".claude" / "active-sessions-state.txt"
GENERATING_SECS = 90  # jsonl written this recently while running => generating
ICON_TMP = Path.home() / ".claude" / "session-icon-tmp.png"
ICON_HASHES = Path.home() / ".claude" / "session-icon-hashes.json"
PROJECT_MAP = Path.home() / ".claude" / "session-projects.json"

try:
    _proj_map = json.loads(PROJECT_MAP.read_text())
except Exception:
    _proj_map = {"sids": {}, "rules": []}


def categorize(sid, cwd, first):
    """Project folder for a session: pinned sid > rules > cwd basename."""
    pinned = _proj_map.get("sids", {}).get(sid)
    if pinned:
        return pinned
    hay = f"{cwd} | {first[:200]}"
    for pat, name in _proj_map.get("rules", []):
        try:
            if re.search(pat, hay, re.I):
                return name
        except re.error:
            continue
    return os.path.basename(cwd) or "Other"

_FONT = ImageFont.truetype("/System/Library/Fonts/Menlo.ttc", 46)
_FONT_BOLD = ImageFont.truetype("/System/Library/Fonts/Menlo.ttc", 22, index=1)
_FONT_SM = ImageFont.truetype("/System/Library/Fonts/Menlo.ttc", 26)
_FONT_SM_BOLD = ImageFont.truetype("/System/Library/Fonts/Menlo.ttc", 28, index=1)
ICON_VER = "v6"  # bump to force re-render of all icons

INFO_PLIST = """<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundlePackageType</key><string>APPL</string>
	<key>CFBundleExecutable</key><string>run</string>
	<key>CFBundleIconFile</key><string>icon</string>
	<key>CFBundleIdentifier</key><string>com.hico.claude-session</string>
	<key>CFBundleName</key><string>{name}</string>
	<key>LSUIElement</key><true/>
</dict>
</plist>
"""

RUN_SCRIPT = """#!/bin/bash
DIR="$(cd "$(dirname "$0")/.." && pwd)"
exec open -a Terminal "$DIR/Resources/session.command"
"""

RESUME_ACTIVE_BODY = """#!/bin/bash
# Reopen every session recorded as active (written each minute by the refresh daemon).
STATE="$HOME/.claude/active-sessions-state.txt"
[ -s "$STATE" ] || { echo "no active sessions recorded"; sleep 2; exit 0; }
while IFS='|' read -r sid cwd bounds; do
  [ -d "$cwd" ] || continue
  pgrep -f "claude .*--resume $sid" >/dev/null && continue  # already open
  osascript -e "tell application \\"Terminal\\" to do script \\"cd '$cwd' && claude --dangerously-skip-permissions --resume $sid\\"" >/dev/null
  [ -n "$bounds" ] && osascript -e "tell application \\"Terminal\\" to set bounds of front window to {$bounds}" >/dev/null
done < "$STATE"
"""

RESTORE_HANDOVER_BODY = """#!/bin/bash
exec "$HOME/bin/claude-restore-handover"
"""

try:
    _icon_hashes = json.loads(ICON_HASHES.read_text())
except Exception:
    _icon_hashes = {}


def text_of(msg):
    c = msg.get("content")
    if isinstance(c, str):
        return c
    if isinstance(c, list):
        return " ".join(p.get("text", "") for p in c if isinstance(p, dict) and p.get("type") == "text")
    return ""


def head_info(path):
    """Return (cwd, first_user_message) from the start of a session file."""
    cwd, first = None, None
    with open(path, "r", errors="replace") as f:
        for _ in range(30):
            line = f.readline()
            if not line:
                break
            try:
                d = json.loads(line)
            except json.JSONDecodeError:
                continue
            cwd = cwd or d.get("cwd")
            if first is None and d.get("type") == "user":
                t = text_of(d.get("message", {})).strip()
                if t:
                    first = t
            if cwd and first:
                break
    return cwd, first


def tail_messages(path, n=12):
    """Last n user/assistant text messages, for the icon and QL preview."""
    size = os.path.getsize(path)
    with open(path, "rb") as f:
        f.seek(max(0, size - 300_000))
        chunk = f.read().decode("utf-8", errors="replace")
    msgs = []
    for line in chunk.splitlines():
        try:
            d = json.loads(line)
        except json.JSONDecodeError:
            continue
        if d.get("type") not in ("user", "assistant"):
            continue
        t = re.sub(r"\[Image[^\]]*\]", "", text_of(d.get("message", {})))
        t = re.sub(r"\s+", " ", t).strip()
        if not t or t.startswith("<"):  # skip tool results / system reminders
            continue
        who = "you" if d.get("type") == "user" else "claude"
        msgs.append((who, t[:400]))
    return msgs[-n:]


def running_claude():
    """Return ({sid: tty}, {cwd: tty}) of live claude processes."""
    sids, cwds = {}, {}
    try:
        ps = subprocess.run(["ps", "-axo", "pid=,tty=,command="], capture_output=True, text=True).stdout
    except Exception:
        return sids, cwds
    for line in ps.splitlines():
        parts = line.strip().split(None, 2)
        if len(parts) < 3:
            continue
        pid, tty, cmd = parts
        if not re.search(r"(^|/)claude( |$)", cmd.split(" -")[0]) and " claude " not in f" {cmd} ":
            continue
        if "claude-sessions-refresh" in cmd:
            continue
        tty = "" if tty in ("??", "-") else tty
        m = re.search(r"--resume\s+([0-9a-f-]{36})", cmd)
        if m:
            sids[m.group(1)] = tty
        try:
            out = subprocess.run(["lsof", "-a", "-p", pid, "-d", "cwd", "-Fn"],
                                 capture_output=True, text=True, timeout=5).stdout
            for l in out.splitlines():
                if l.startswith("n"):
                    cwds[l[1:]] = tty
        except Exception:
            pass
    return sids, cwds


def terminal_bounds():
    """Map tty ('ttys004') -> Terminal window bounds 'x1,y1,x2,y2'."""
    script = '''set out to ""
tell application "Terminal"
	repeat with w in windows
		try
			set b to bounds of w
			set bs to ((item 1 of b) as text) & "," & ((item 2 of b) as text) & "," & ((item 3 of b) as text) & "," & ((item 4 of b) as text)
			repeat with t in tabs of w
				set out to out & (tty of t) & "|" & bs & linefeed
			end repeat
		end try
	end repeat
end tell
return out'''
    m = {}
    try:
        out = subprocess.run(["osascript", "-e", script],
                             capture_output=True, text=True, timeout=10).stdout
        for line in out.splitlines():
            tty, _, bounds = line.partition("|")
            tty = tty.strip().removeprefix("/dev/")
            if tty and bounds.strip():
                m[tty] = bounds.strip()
    except Exception:
        pass
    return m


def make_terminal_icon(proj, msgs, dot, dest):
    """Render a mini terminal window with the session's last messages -> icns."""
    S = 512
    img = Image.new("RGBA", (S, S), (0, 0, 0, 0))
    d = ImageDraw.Draw(img)
    d.rounded_rectangle([2, 2, S - 2, S - 2], radius=42, fill=(24, 26, 31, 255),
                        outline=(70, 74, 82, 255), width=2)
    d.rounded_rectangle([2, 2, S - 2, 52], radius=42, fill=(38, 41, 48, 255))
    d.rectangle([2, 30, S - 2, 52], fill=(38, 41, 48, 255))
    for i, c in enumerate([(255, 95, 87), (254, 188, 46), (40, 200, 64)]):
        d.ellipse([24 + i * 32, 16, 46 + i * 32, 38], fill=c)
    title = proj[:24]
    d.text((140, 16), title, font=_FONT_BOLD, fill=(170, 175, 185))
    if dot:
        col = (217, 119, 87) if dot.startswith("⚡") else (40, 200, 64)
        d.ellipse([S - 48, 14, S - 22, 40], fill=col)
    # zoomed view: your last prompt (2 lines) + claude's latest output (rest)
    last_you = next((t for w, t in reversed(msgs) if w == "you"), "")
    last_claude = next((t for w, t in reversed(msgs) if w == "claude"), "")
    y = 66
    W = 16  # chars per line at this font size
    for who, text, maxlines in [("you", last_you, 2), ("claude", last_claude, 6)]:
        text = re.sub(r"[^\x20-\x7e]", "", text).strip()
        if not text:
            continue
        pcol = (217, 119, 87) if who == "you" else (150, 200, 150)
        tcol = (240, 240, 237) if who == "you" else (185, 191, 201)
        for j, chunk in enumerate([text[k:k + W] for k in range(0, len(text), W)][:maxlines]):
            if y > S - 56:
                break
            if j == 0:
                d.text((14, y), ">" if who == "you" else "*", font=_FONT, fill=pcol)
            d.text((48, y), chunk, font=_FONT, fill=tcol)
            y += 54
        y += 8
    img.save(ICON_TMP)
    subprocess.run(["sips", "-s", "format", "icns", str(ICON_TMP), "--out", str(dest)],
                   capture_output=True)


def make_detail_preview(proj, msgs, dot, dest):
    """Large hover preview: the full recent conversation in readable type."""
    S = 1024
    img = Image.new("RGBA", (S, S), (0, 0, 0, 0))
    d = ImageDraw.Draw(img)
    d.rounded_rectangle([2, 2, S - 2, S - 2], radius=36, fill=(24, 26, 31, 250),
                        outline=(80, 84, 92, 255), width=2)
    d.rounded_rectangle([2, 2, S - 2, 78], radius=36, fill=(38, 41, 48, 255))
    d.rectangle([2, 44, S - 2, 78], fill=(38, 41, 48, 255))
    for i, c in enumerate([(255, 95, 87), (254, 188, 46), (40, 200, 64)]):
        d.ellipse([36 + i * 46, 24, 68 + i * 46, 56], fill=c)
    tw = d.textlength(proj[:40], font=_FONT_SM_BOLD)
    d.text(((S - tw) / 2, 26), proj[:40], font=_FONT_SM_BOLD, fill=(180, 185, 195))
    if dot:
        col = (217, 119, 87) if dot.startswith("⚡") else (40, 200, 64)
        d.ellipse([S - 70, 24, S - 38, 56], fill=col)
    y = 104
    W = 58  # chars per line
    LH = 34
    for who, text in msgs:
        text = re.sub(r"[^\x20-\x7e]", "", text).strip()
        if not text:
            continue
        pcol = (217, 119, 87) if who == "you" else (150, 200, 150)
        tcol = (240, 240, 237) if who == "you" else (185, 191, 201)
        for j, chunk in enumerate([text[k:k + W].lstrip() for k in range(0, len(text), W)][:4]):
            if y > S - LH - 24:
                break
            if j == 0:
                d.text((28, y), ">" if who == "you" else "*", font=_FONT_SM, fill=pcol)
            d.text((64, y), chunk, font=_FONT_SM, fill=tcol)
            y += LH
        y += 14
        if y > S - LH - 24:
            break
    img.save(dest)


_PALETTE = [(217, 119, 87), (95, 158, 217), (120, 190, 120), (200, 140, 210),
            (222, 184, 78), (110, 200, 190), (230, 120, 140), (150, 150, 220)]


def accent_for(name):
    return _PALETTE[int(hashlib.md5(name.encode()).hexdigest(), 16) % len(_PALETTE)]


_FONT_TITLE = ImageFont.truetype("/System/Library/Fonts/Menlo.ttc", 58, index=1)
_FONT_SUB = ImageFont.truetype("/System/Library/Fonts/Menlo.ttc", 34)


def make_folder_icon(name, total, gen, wait, folder_path, unit="session"):
    """Custom icon for a project folder: name, session count, status badges."""
    S = 512
    ac = accent_for(name)
    img = Image.new("RGBA", (S, S), (0, 0, 0, 0))
    d = ImageDraw.Draw(img)
    d.rounded_rectangle([10, 96, S - 10, S - 20], radius=44, fill=(28, 30, 36, 255),
                        outline=(*ac, 255), width=5)
    d.rounded_rectangle([10, 40, 240, 140], radius=30, fill=ac)  # folder tab
    d.rectangle([10, 96, 240, 120], fill=ac)
    # project name, wrapped to two lines
    display = re.sub(r"^\d+\s+", "", name)
    words, lines, cur = display.split(), [], ""
    for w in words:
        if len(cur) + len(w) + 1 <= 12:
            cur = (cur + " " + w).strip()
        else:
            lines.append(cur)
            cur = w
    lines.append(cur)
    y = 180
    for line in lines[:2]:
        tw = d.textlength(line, font=_FONT_TITLE)
        d.text(((S - tw) / 2, y), line, font=_FONT_TITLE, fill=(240, 240, 237))
        y += 74
    sub = f"{total} {unit}{'s' if total != 1 else ''}"
    tw = d.textlength(sub, font=_FONT_SUB)
    d.text(((S - tw) / 2, y + 14), sub, font=_FONT_SUB, fill=(160, 166, 176))
    bx = S / 2 - (46 * ((gen > 0) + (wait > 0))) / 2
    for count, col in [(gen, (217, 119, 87)), (wait, (40, 200, 64))]:
        if count:
            d.ellipse([bx, y + 78, bx + 34, y + 112], fill=col)
            d.text((bx + 40, y + 76), str(count), font=_FONT_SUB, fill=col)
            bx += 92
    img.save(ICON_TMP)
    ns = NSImage.alloc().initWithContentsOfFile_(str(ICON_TMP))
    NSWorkspace.sharedWorkspace().setIcon_forFile_options_(ns, str(folder_path), 0)


def make_glyph_icon(kind, accent, dest):
    """Icon for an action launcher: 'plus' or 'play' glyph on a dark tile."""
    S = 512
    img = Image.new("RGBA", (S, S), (0, 0, 0, 0))
    d = ImageDraw.Draw(img)
    d.rounded_rectangle([10, 10, S - 10, S - 10], radius=64, fill=(28, 30, 36, 255),
                        outline=(*accent, 255), width=6)
    c, r, t = S / 2, 120, 26
    if kind == "plus":
        d.rounded_rectangle([c - r, c - t, c + r, c + t], radius=t, fill=accent)
        d.rounded_rectangle([c - t, c - r, c + t, c + r], radius=t, fill=accent)
    elif kind == "restore":  # lifebuoy ring
        d.ellipse([c - r - 20, c - r - 20, c + r + 20, c + r + 20],
                  outline=accent, width=64)
    elif kind == "edit":  # pencil: diagonal shaft + tip
        d.line([(c - 90, c + 90), (c + 70, c - 70)], fill=accent, width=52)
        d.polygon([(c - 130, c + 130), (c - 96, c + 62), (c - 62, c + 96)], fill=accent)
        d.line([(c + 46, c - 94), (c + 94, c - 46)], fill=accent, width=52)
    else:  # play triangle
        d.polygon([(c - 80, c - 110), (c - 80, c + 110), (c + 120, c)], fill=accent)
    img.save(ICON_TMP)
    subprocess.run(["sips", "-s", "format", "icns", str(ICON_TMP), "--out", str(dest)],
                   capture_output=True)


def make_action(app, title, kind, accent, script_body, wanted, out_root):
    """Write a small action launcher bundle (clickable in the Dock grid)."""
    res = app / "Contents" / "Resources"
    macos = app / "Contents" / "MacOS"
    res.mkdir(parents=True, exist_ok=True)
    macos.mkdir(parents=True, exist_ok=True)
    write_if_changed(app / "Contents" / "Info.plist", INFO_PLIST.format(name=title))
    write_if_changed(macos / "run", RUN_SCRIPT, mode=0o755)
    write_if_changed(res / "session.command", script_body, mode=0o755)
    if not (res / "icon.icns").exists():
        make_glyph_icon(kind, accent, res / "icon.icns")
    wanted.add(str(app.relative_to(out_root)))


def write_if_changed(path, content, mode=None):
    if not path.exists() or path.read_text() != content:
        path.write_text(content)
    if mode:
        path.chmod(mode)


def main():
    sessions = []
    for f in PROJECTS.glob("*/*.jsonl"):
        st = f.stat()
        if st.st_size < MIN_BYTES:
            continue
        sessions.append((st.st_mtime, f))
    sessions.sort(reverse=True)

    picked = []
    for mtime, f in sessions:
        if len(picked) >= MAX_SESSIONS:
            break
        cwd, first = head_info(f)
        if not cwd or cwd == "/" or not os.path.isdir(cwd):
            continue
        if first and re.match(r"(You are (an?|the) |Reply with )", first):
            continue  # automated job prompt, not interactive work
        picked.append((mtime, f, cwd, first or ""))

    OUT.mkdir(exist_ok=True)
    live_sids, live_cwds = running_claude()
    ttymap = terminal_bounds() if (live_sids or live_cwds) else {}
    seen_live_cwd = set()
    now = time.time()
    active_state = []
    wanted = set()

    counters = {}
    folder_stats = {}
    gidx = 0
    (OUT / "1 All Sessions").mkdir(exist_ok=True)
    (OUT / "2 Projects").mkdir(exist_ok=True)
    for mtime, f, cwd, first in picked:
        sid = f.stem
        proj = os.path.basename(cwd)
        folder = re.sub(r"[/:]", "-", categorize(sid, cwd, first))
        counters[folder] = counters.get(folder, 0) + 1
        i = counters[folder]
        # active = a claude process is resumed on this session, or one is
        # running in this folder and this is the folder's newest session
        active = sid in live_sids or (cwd in live_cwds and cwd not in seen_live_cwd)
        if cwd in live_cwds:
            seen_live_cwd.add(cwd)
        if active:
            tty = live_sids.get(sid) or live_cwds.get(cwd) or ""
            active_state.append(f"{sid}|{cwd}|{ttymap.get(tty, '')}")
            dot = "⚡ " if now - mtime < GENERATING_SECS else "🟢 "
        else:
            dot = ""
        stx = folder_stats.setdefault(folder, {"total": 0, "gen": 0, "wait": 0, "cwd": cwd})
        stx["total"] += 1
        if dot == "⚡ ":
            stx["gen"] += 1
        elif dot == "🟢 ":
            stx["wait"] += 1
        snippet = re.sub(r"[/:\n\r]", " ", first)[:45].strip()
        base = f"{i:02d} {dot}{proj} — {snippet}" if snippet else f"{i:02d} {dot}{proj}"
        when = time.strftime("%a %b %d %H:%M", time.localtime(mtime))
        msgs = tail_messages(f)
        preview = "\n".join(f"#  [{who}] {t}" for who, t in msgs)
        body = f"""#!/bin/bash
#  ══════════════════════════════════════════════════
#  Claude session — {proj}{"  ·  " + ("⚡ GENERATING" if dot == "⚡ " else "🟢 RUNNING, waiting for you") if active else ""}
#  Folder:      {cwd}
#  Last active: {when}
#  Session id:  {sid}
#  ══════════════════════════════════════════════════
#
#  Recent conversation:
#
{preview}
#
#  ══════════════════════════════════════════════════
cd '{cwd}' && exec claude --dangerously-skip-permissions --resume {sid}
"""
        app = OUT / "2 Projects" / folder / f"{base}.app"
        res = app / "Contents" / "Resources"
        macos = app / "Contents" / "MacOS"
        res.mkdir(parents=True, exist_ok=True)
        macos.mkdir(parents=True, exist_ok=True)
        write_if_changed(app / "Contents" / "Info.plist", INFO_PLIST.format(name=proj))
        write_if_changed(macos / "run", RUN_SCRIPT, mode=0o755)
        write_if_changed(res / "session.command", body, mode=0o755)

        rel = str(app.relative_to(OUT))
        key = hashlib.md5(repr((ICON_VER, proj, msgs, dot)).encode()).hexdigest()
        if _icon_hashes.get(rel) != key or not (res / "icon.icns").exists():
            try:
                make_terminal_icon(proj, msgs, dot, res / "icon.icns")
                make_detail_preview(proj, msgs, dot, res / "preview.png")
                app.touch()  # nudge Finder/Dock icon cache
                _icon_hashes[rel] = key
            except Exception:
                pass  # never let icon rendering break the launcher list
        wanted.add(rel)

        # flat chronological view: symlink into "All Sessions"
        gidx += 1
        alink = OUT / "1 All Sessions" / f"{gidx:03d} {dot}{proj} — {snippet}.app"
        if alink.is_symlink():
            if alink.readlink() != app:
                alink.unlink()
                alink.symlink_to(app)
        else:
            alink.symlink_to(app)
        wanted.add(str(alink.relative_to(OUT)))

    # action launchers + custom folder icons
    make_action(OUT / "0 🛟 Restore All.app", "Restore All", "restore",
                (95, 158, 217), RESTORE_HANDOVER_BODY, wanted, OUT)
    make_action(OUT / "4 ⚡ Resume Active.app", "Resume Active", "play",
                (217, 119, 87), RESUME_ACTIVE_BODY, wanted, OUT)
    make_action(OUT / "3 ➕ New Session.app", "New Session", "plus",
                (120, 190, 120),
                f"#!/bin/bash\ncd \"$HOME\" && exec claude --dangerously-skip-permissions\n",
                wanted, OUT)
    folder_keys = set()
    for folder, stx in folder_stats.items():
        fdir = OUT / "2 Projects" / folder
        make_action(fdir / "00 ➕ New Session.app", "New Session", "plus",
                    accent_for(folder),
                    f"#!/bin/bash\ncd '{stx['cwd']}' && exec claude --dangerously-skip-permissions\n",
                    wanted, OUT)
        make_action(fdir / "00 ✏️ Edit Sessions.app", "Edit Sessions", "edit",
                    (222, 184, 78),
                    f"#!/bin/bash\nexec \"$HOME/bin/claude-session-edit\" '{folder}'\n",
                    wanted, OUT)
        fkey = hashlib.md5(repr((ICON_VER, folder, stx["total"], stx["gen"], stx["wait"])).encode()).hexdigest()
        hk = f"__folder__/{folder}"
        folder_keys.add(hk)
        if _icon_hashes.get(hk) != fkey:
            try:
                make_folder_icon(folder, stx["total"], stx["gen"], stx["wait"], fdir)
                _icon_hashes[hk] = fkey
            except Exception:
                pass
    tg = sum(s["gen"] for s in folder_stats.values())
    tw = sum(s["wait"] for s in folder_stats.values())
    for name, total, hkname in [("1 All Sessions", gidx, "__top__/all"),
                                ("2 Projects", len(folder_stats), "__top__/projects")]:
        fkey = hashlib.md5(repr((ICON_VER, name, total, tg, tw)).encode()).hexdigest()
        folder_keys.add(hkname)
        if _icon_hashes.get(hkname) != fkey:
            try:
                make_folder_icon(name, total, tg, tw, OUT / name, unit=("project" if name.endswith("Projects") else "session"))
                _icon_hashes[hkname] = fkey
            except Exception:
                pass

    # drop launchers that no longer apply (renamed status, pruned sessions) —
    # done after writing so the folder is never empty if clicked mid-refresh
    for old in OUT.rglob("*.app"):
        if str(old.relative_to(OUT)) not in wanted:
            if old.is_symlink():
                old.unlink()
            else:
                shutil.rmtree(old)
    for old in OUT.glob("*.command"):
        old.unlink()
    for sub in list(OUT.glob("*")) + list((OUT / "2 Projects").glob("*")):
        if (sub.is_dir() and not sub.is_symlink() and sub.suffix != ".app"
                and sub.name not in ("1 All Sessions", "2 Projects")
                and not any(sub.glob("*.app"))):
            shutil.rmtree(sub)

    for k in list(_icon_hashes):
        if k not in wanted and k not in folder_keys:
            del _icon_hashes[k]
    ICON_HASHES.write_text(json.dumps(_icon_hashes))

    # record what's running so claude-respawn can restore it after a reboot
    STATE.write_text("\n".join(active_state) + ("\n" if active_state else ""))

    print(f"wrote {len(picked)} launchers to {OUT}, {len(active_state)} active")


if __name__ == "__main__":
    main()
